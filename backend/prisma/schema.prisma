generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameClass {
  ADVENTURER
  ARCHER
  MAGE
  SWORDSMAN
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String?  
  isVerified          Boolean   @default(false)
  name                String?

  image               String?
  
  gender              String?   @default("adventurer") 
  isOnboarded         Boolean   @default(false)

  role                Role      @default(USER)
  xp                  Int       @default(0)
  level               Int       @default(1)

  class               GameClass @default(ADVENTURER)

  gold                Int       @default(0)
  lastRewardClaimedAt DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  tasks               Task[]

  inventory           String[]

  monsterHp           Int?
  monsterMaxHp        Int?
  monsterEndTime      DateTime?
  nextInvasionTime    DateTime?

  monsterSenderName String?
  pendingInvasions  PendingInvasion[] @relation("TargetInvasions")

  equippedTheme       String?
  equippedFrame       String?
  equippedTitle       String?

  streakCount         Int       @default(0)
  lastDailyRewardAt   DateTime?

  streakFreezes       Int       @default(0)
  doubleXpUntil       DateTime?
  doubleXpPotions     Int       @default(0) 

  userTag          String?
  sentRequests     Friendship[] @relation("SentRequests")
  receivedRequests Friendship[] @relation("ReceivedRequests")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  xp          Int        @default(10)
  gainedXp    Int?  
  
  completed   Boolean    @default(false)
  completedAt DateTime?
  timeSpent   Int?      
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  difficulty  Difficulty @default(EASY)

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EPIC
}

enum Role {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester   User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model PendingInvasion {
  id          String   @id @default(uuid())
  targetId    String
  senderName  String   // Le pseudo de l'ami qui a envoyé le monstre
  createdAt   DateTime @default(now())

  target      User     @relation("TargetInvasions", fields: [targetId], references: [id], onDelete: Cascade)
}